# TMDB: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
# Use real TMDB API in development (npm run dev). Omit or set to false for mock data.
# TMDB_USE_REAL_API=true

# SQLite for local dev (path relative to project root)
DATABASE_URL="file:./dev.db"

# NextAuth: generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Production behind Docker / proxy: trust the Host header (same as auth trustHost)
# AUTH_TRUST_HOST=true

# Optional — set in your shell if you don’t use npm scripts (not read automatically):
# NODE_OPTIONS=--max-old-space-size=8192
