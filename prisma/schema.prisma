generator client {
  provider      = "prisma-client-js"
  // Docker build/run = Debian (see Dockerfile). `native` = local dev (macOS/Windows).
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  watchlist       WatchlistItem[]
  watchlistShows  WatchlistShowItem[]
  progress        WatchProgress[]
  episodeProgress EpisodeProgress[]
}

model WatchlistItem {
  userId   String
  movieId  String
  addedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, movieId])
  @@index([userId])
}

model WatchlistShowItem {
  userId   String
  showId   String
  addedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, showId])
  @@index([userId])
}

model WatchProgress {
  userId          String
  movieId         String
  progressSeconds Int      @default(0)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, movieId])
  @@index([userId, updatedAt])
}

model EpisodeProgress {
  userId          String
  showId          String
  seasonNumber    Int
  episodeNumber   Int
  progressSeconds Int      @default(0)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, showId, seasonNumber, episodeNumber])
  @@index([userId, updatedAt])
}
