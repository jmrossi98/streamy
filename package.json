{
  "name": "streamy",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "prisma generate && prisma migrate deploy && next dev --turbo",
    "dev:turbo": "next dev --turbo",
    "dev:webpack": "next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 prisma generate && cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "npm run start:prod",
    "start:prod": "npm run build && prisma migrate deploy && node .next/standalone/server.js",
    "start:serve": "prisma migrate deploy && node .next/standalone/server.js",
    "start:watch": "nodemon --config nodemon.json",
    "lint": "npx next lint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5"
  }
}
