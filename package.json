{
  "name": "streamy",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "prisma generate && prisma migrate deploy && next dev --turbo",
    "dev:turbo": "next dev --turbo",
    "dev:webpack": "next dev",
    "build": "prisma generate && npx next build",
    "start": "npm run build && npx next start",
    "start:watch": "nodemon --watch src --watch prisma --watch next.config.mjs --watch tailwind.config.* --watch postcss.config.* --ext ts,tsx,js,mjs,cjs,json,prisma --ignore node_modules --ignore .next --exec \"npm run build && npx next start\"",
    "lint": "npx next lint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5"
  }
}
